@model EmployeeAssetManagementSystem.Models.Asset

@{
    ViewData["Title"] = "Asset Details";
}

<div class="mb-4">
    <h2 class="fw-bold">Employee Details</h2>
</div>

@* Header *@
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Asset Name</dt>
            <dd class="col-sm-9">@Model.AssetName</dd>

            <dt class="col-sm-3">Serial Number</dt>
            <dd class="col-sm-9">@Model.SerialNumber</dd>

            <dt class="col-sm-3">Asset Type</dt>
            <dd class="col-sm-9">@Model.AssetType</dd>

            <dt class="col-sm-3">Purchase Date</dt>
            <dd class="col-sm-9">@Model.PurchaseDate.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@(Model.IsAvailable ? "Available" : "Unavailable")</dd>
        </dl>
    </div>
</div>

<div class="mt-3 text-end">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>