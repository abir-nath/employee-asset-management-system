@model EmployeeAssetManagementSystem.Models.Asset

@{
    ViewData["Title"] = "Asset Details";
}

<div class="mb-4">
    <h2 class="fw-bold">Asset Details</h2>
</div>

@* Header *@
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Asset Name</dt>
            <dd class="col-sm-9">@Model.AssetName</dd>

            <dt class="col-sm-3">Serial Number</dt>
            <dd class="col-sm-9">@Model.SerialNumber</dd>

            <dt class="col-sm-3">Asset Type</dt>
            <dd class="col-sm-9">@Model.AssetType</dd>

            <dt class="col-sm-3">Purchase Date</dt>
            <dd class="col-sm-9">@Model.PurchaseDate.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@(Model.IsAvailable ? "Available" : "Unavailable")</dd>
        </dl>
    </div>
</div>

@if (Model.EmployeeAssets != null && Model.EmployeeAssets.Any())
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <h4 class="mb-3">Assigned Assets</h4>
            <table class="table table-hover table-bordered align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Employee ID</th>
                        <th>Employee Name</th>
                        <th>Assigned Date</th>
                        <th>Returned Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ea in Model.EmployeeAssets)
                    {
                        <tr>
                            <td>@ea.Employee?.Id</td>
                            <td>@ea.Employee?.FullName</td>
                            <td>@ea.AssignedDate.ToString("dd MMM yyyy")</td>
                            <td>@(ea.ReturnedDate.HasValue? ea.ReturnedDate.Value.ToString("dd MMM yyyy") : "-")</td>
                            <td>@ea.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        No assets assigned to this employee.
    </div>
}

<div class="mt-3 text-end">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back
    </a>
</div>