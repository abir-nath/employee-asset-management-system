@model EmployeeAssetManagementSystem.Models.EmployeeAsset

<div class="card shadow-sm border-0">
    <div class="card-body">

    
        <div class="mb-3">
            <label asp-for="EmployeeId" class="form-label fw-semibold">
                Employee <span class="text-danger">*</span>
            </label>
            <select asp-for="EmployeeId"
                    class="form-select"
                    asp-items=@(ViewData["Employees"] as SelectList)">
                <option value="">-- Select Employee --</option>
            </select>
            <span asp-validation-for="EmployeeId" class="text-danger small"></span>
        </div>

     
        <div class="mb-3">
            <label asp-for="AssetId" class="form-label fw-semibold">
                Asset <span class="text-danger">*</span>
            </label>
            <select asp-for="AssetId"
                    class="form-select"
                    asp-items=@(ViewData["Assets"] as SelectList)">
                <option value="">-- Select Asset --</option>
            </select>
            <span asp-validation-for="AssetId" class="text-danger small"></span>
        </div>

      
        <div class="mb-3">
            <label asp-for="AssignedDate" class="form-label fw-semibold">
                Assigned Date <span class="text-danger">*</span>
            </label>
            <input asp-for="AssignedDate"
                   type="date"
                   class="form-control"
                   value="@(Model.AssignedDate == DateTime.MinValue ? "" : Model.AssignedDate.ToString("yyyy-MM-dd"))" />
            <span asp-validation-for="AssignedDate" class="text-danger small"></span>
        </div>

      
        <div class="mb-3">
            <label asp-for="Status" class="form-label fw-semibold">
                Status <span class="text-danger">*</span>
            </label>
            <select asp-for="Status" class="form-select" id="statusSelect">
                <option value="Assigned">Assigned</option>
                <option value="Returned">Returned</option>
            </select>
            <span asp-validation-for="Status" class="text-danger small"></span>
        </div>

     
        <div class="mb-3"
             id="returnedDateContainer"
             style="display:@(Model.Status == "Returned" ? "block" : "none");">

            <label asp-for="ReturnedDate" class="form-label fw-semibold">
                Returned Date <span class="text-danger">*</span>
            </label>

            <input asp-for="ReturnedDate" type="date" class="form-control" />
            <span asp-validation-for="ReturnedDate" class="text-danger small"></span>
        </div>

    </div>
</div>

<script>
    const statusSelect = document.getElementById("statusSelect");
    const returnedContainer = document.getElementById("returnedDateContainer");

    if (statusSelect) {
        statusSelect.addEventListener("change", function () {
            returnedContainer.style.display =
                this.value === "Returned" ? "block" : "none";
        });
    }
</script>