@{
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EAMS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background-color: #f4f6f9;
        }

        /* SIDEBAR */
        .sidebar {
            width: 250px;
            min-height: 100vh;
            background: #ffffff;
            position: fixed;
            border-right: 1px solid #e5e7eb;
            transition: all 0.3s ease;
            overflow: hidden;
        }

            .sidebar.collapsed {
                width: 70px;
            }

            .sidebar .brand {
                padding: 20px;
                font-weight: 600;
                border-bottom: 1px solid #e5e7eb;
                white-space: nowrap;
            }

                .sidebar .brand img {
                    height: 30px;
                }

            .sidebar a {
                color: #374151;
                text-decoration: none;
                padding: 12px 20px;
                display: flex;
                align-items: center;
                font-weight: 500;
                transition: all 0.2s ease;
                white-space: nowrap;
            }

                .sidebar a i {
                    min-width: 25px;
                }

                .sidebar a:hover {
                    background-color: #f3f4f6;
                }

                .sidebar a.active-link {
                    background-color: #e0f2fe;
                    color: #0c4a6e !important;
                    border-left: 4px solid #0ea5e9;
                    font-weight: 600;
                }

            /* Hide text when collapsed */
            .sidebar.collapsed span.menu-text,
            .sidebar.collapsed .brand span {
                display: none;
            }

        /* CONTENT */
        .content-wrapper {
            margin-left: 250px;
            transition: all 0.3s ease;
        }

            .content-wrapper.expanded {
                margin-left: 70px;
            }

        /* TOPBAR */
        .topbar {
            height: 60px;
            background-color: #ffffff;
            border-bottom: 1px solid #e5e7eb;
        }

        .app-title {
            font-weight: 600;
            font-size: 1.1rem;
        }

        .user-box {
            font-weight: 500;
        }

        .toggle-btn {
            font-size: 1.4rem;
            cursor: pointer;
            margin-right: 15px;
        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div id="sidebar" class="sidebar d-flex flex-column">

        <div class="brand d-flex align-items-center">
            <img src="~/images/logo.png" alt="Logo" class="me-2" />
            <span>EAMS</span>
        </div>

        <a asp-controller="Home" asp-action="Index"
           class="nav-link @(currentController == "Home" ? "active-link" : "")"
           data-bs-toggle="tooltip"
           data-bs-placement="right"
           title="Dashboard">
            <i class="bi bi-speedometer2"></i>
            <span class="menu-text ms-2">Dashboard</span>
        </a>

        <a asp-controller="Employees" asp-action="Index"
           class="nav-link @(currentController == "Employees" ? "active-link" : "")"
           data-bs-toggle="tooltip"
           data-bs-placement="right"
           title="Employees">
            <i class="bi bi-people"></i>
            <span class="menu-text ms-2">Employees</span>
        </a>

        <a asp-controller="Assets" asp-action="Index"
           class="nav-link @(currentController == "Assets" ? "active-link" : "")"
           data-bs-toggle="tooltip"
           data-bs-placement="right"
           title="Assets">
            <i class="bi bi-laptop"></i>
            <span class="menu-text ms-2">Assets</span>
        </a>

        <a asp-controller="EmployeeAssets" asp-action="Index"
           class="nav-link @(currentController == "EmployeeAssets" ? "active-link" : "")"
           data-bs-toggle="tooltip"
           data-bs-placement="right"
           title="Assign Assets">
            <i class="bi bi-link-45deg"></i>
            <span class="menu-text ms-2">Assign Assets</span>
        </a>

    </div>

    <!-- CONTENT -->
    <div id="content" class="content-wrapper">

        <!-- TOPBAR -->
        <div class="topbar d-flex justify-content-between align-items-center px-4">

            <div class="d-flex align-items-center">
                <i class="bi bi-list toggle-btn" onclick="toggleSidebar()"></i>
                <div class="app-title">
                    Employee Asset Management System
                </div>
            </div>

            <!-- USER RIGHT CORNER -->
            <div class="user-box d-flex align-items-center ms-auto">

    <div class="text-end me-3">
        <div>John Doe</div>
        <small class="text-muted">Administrator</small>
    </div>

    <i class="bi bi-person-circle fs-4 me-3 text-secondary"></i>

    <!-- LOGOUT BUTTON -->
    <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
        <button type="submit" class="btn btn-outline-danger btn-sm">
            <i class="bi bi-box-arrow-right me-1"></i> Logout
        </button>
    </form>

</div>

        </div>

        <!-- MAIN CONTENT -->
        <div class="container-fluid p-4">
            @RenderBody()
        </div>

    </div>

    <script>
        const sidebar = document.getElementById("sidebar");
        const content = document.getElementById("content");

        document.addEventListener("DOMContentLoaded", function () {

            // Restore sidebar state
            const isCollapsed = localStorage.getItem("sidebarCollapsed");

            if (isCollapsed === "true") {
                sidebar.classList.add("collapsed");
                content.classList.add("expanded");
            }

            // Enable Bootstrap tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });

        function toggleSidebar() {
            sidebar.classList.toggle("collapsed");
            content.classList.toggle("expanded");

            localStorage.setItem(
                "sidebarCollapsed",
                sidebar.classList.contains("collapsed")
            );
        }

        // Auto collapse on menu click
        document.querySelectorAll(".nav-link").forEach(link => {
            link.addEventListener("click", function () {
                sidebar.classList.add("collapsed");
                content.classList.add("expanded");
                localStorage.setItem("sidebarCollapsed", "true");
            });
        });
    </script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>