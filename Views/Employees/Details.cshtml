@model EmployeeAssetManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<div class="mb-4">
    <h2 class="fw-bold">Employee Details</h2>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to List
    </a>
</div>

@* Header *@
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Full Name</dt>
            <dd class="col-sm-9">@Model.FullName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Department</dt>
            <dd class="col-sm-9">@Model.Department</dd>

            <dt class="col-sm-3">Joining Date</dt>
            <dd class="col-sm-9">@Model.JoiningDate.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3">Active</dt>
            <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
        </dl>
    </div>
</div>

@if (Model.EmployeeAssets != null && Model.EmployeeAssets.Any())
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <h4 class="mb-3">Assigned Assets</h4>
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Asset Name</th>
                        <th>Asset Type</th>
                        <th>Assigned Date</th>
                        <th>Returned Date</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ea in Model.EmployeeAssets)
                    {
                        <tr>
                            <td>@ea.Asset?.AssetName</td>
                            <td>@ea.Asset?.AssetType</td>
                            <td>@ea.AssignedDate.ToString("dd MMM yyyy")</td>
                            <td>@(ea.ReturnedDate.HasValue? ea.ReturnedDate.Value.ToString("dd MMM yyyy") : "-")</td>
                            <td>@ea.Status</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        No assets assigned to this employee.
    </div>
}