@model EmployeeAssetManagementSystem.Models.EmployeeAsset

@{
    ViewData["Title"] = "Assign Asset";
}

<div class="mb-4">
    <h3 class="fw-bold">Assign Asset to Employee</h3>
    <small class="text-muted">Select employee and available asset</small>
</div>

<form asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <partial name="_EmployeeAssetForm" model="Model" />

    <div class="mt-3 text-end">
        <a asp-action="Index" class="btn btn-secondary me-2">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
        <button type="submit" class="btn btn-success">
            <i class="bi bi-check-lg me-1"></i> Assign
        </button>
    </div>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}