@model EmployeeAssetManagementSystem.Models.EmployeeAsset

@{
    ViewData["Title"] = "Edit Assignment";
}

<div class="mb-4">
    <h3 class="fw-bold">Edit Asset Assignment</h3>
    <small class="text-muted">Update status and returned date</small>
</div>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <partial name="_EmployeeAssetForm" model="Model" />

    <div class="mt-3 text-end">
        <a asp-action="Index" class="btn btn-secondary me-2">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-pencil-square me-1"></i> Update
        </button>
    </div>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}